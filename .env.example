# Supabase
SUPABASE_URL=https://xwbkwaapgosfogprjdew.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=          # service_role key, server-side only

# Telegram
TELEGRAM_BOT_TOKEN=
