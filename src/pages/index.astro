---
import BaseLayout from '../layouts/BaseLayout.astro';
import ApartmentCard from '../components/ApartmentCard.astro';
import Hero from '../components/Hero.astro';
import { useTranslations, getLocalePath } from '../i18n/index';
import apartmentsData from '../data/apartments.json';
import '../styles/concierge-hero.css';

const lang = 'it';
const t = useTranslations(lang);
const featured = apartmentsData.slice(0, 3);
const heroImages = [
  apartmentsData[0].gallery[0],
  apartmentsData[1].gallery[0],
  apartmentsData[2].gallery[0],
  apartmentsData[3].gallery[0],
  apartmentsData[4].gallery[0],
  apartmentsData[0].gallery[1],
  apartmentsData[2].gallery[1],
  '/wellness/gym/gym-01.jpg',
  '/wellness/steam/steam-01.jpg',
];

// Mobile hero mosaic: gallery[0] of each apartment + wellness gym shot
const mobileHeroCards = [
  apartmentsData[0].gallery[0],
  apartmentsData[1].gallery[0],
  apartmentsData[2].gallery[0],
  apartmentsData[3].gallery[0],
  apartmentsData[4].gallery[0],
  '/wellness/gym/gym-01.jpg',
];
---

<BaseLayout
  title={t.meta.defaultTitle}
  description={t.meta.defaultDescription}
  lang={lang}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/concierge-hero.jpg" />
  </Fragment>
  <!-- Mobile hero: 2x3 photo mosaic + centered brand + CTAs -->
  <section class="relative md:hidden h-screen w-full overflow-hidden bg-[#0E0E0E]">
    <div class="absolute inset-0 grid grid-cols-2 grid-rows-3 gap-2 p-2">
      {mobileHeroCards.map((src) => (
        <div class="relative rounded-2xl overflow-hidden">
          <img src={src} alt="" class="w-full h-full object-cover" loading="eager" decoding="async" />
        </div>
      ))}
    </div>

    <!-- Dark overlay for legibility -->
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/80"></div>

    <!-- Centered content -->
    <div class="relative z-10 h-full flex flex-col items-center justify-between py-16 px-6">
      <div class="flex-1"></div>

      <div class="flex flex-col items-center gap-4 text-center">
        <img src="/logo-mark.svg" alt="Santopaolo Boutique Apartments" class="w-16 h-16" />
        <div class="flex flex-col items-center gap-2">
          <h1 class="font-display text-3xl font-medium text-[#F5F2EC] leading-none tracking-tight">
            SANTOPAOLO
          </h1>
          <p class="text-[10px] font-medium text-[#F5F2EC]/90 tracking-[0.35em] uppercase whitespace-nowrap">
            Boutique Apartments
          </p>
        </div>
      </div>

      <div class="flex-1"></div>

      <div class="w-full flex flex-row gap-2">
        <a href={getLocalePath(lang, '/apartments')} class="flex-1 text-center bg-[#6B1F1F] hover:bg-[#8A2A2A] text-[#F5F2EC] font-medium tracking-[0.15em] uppercase text-[10px] py-3 px-2 transition-colors">
          Scopri appartamenti
        </a>
        <a href={getLocalePath(lang, '/concierge')} class="flex-1 text-center border border-[#F5F2EC]/40 hover:border-[#F5F2EC] text-[#F5F2EC] font-medium tracking-[0.15em] uppercase text-[10px] py-3 px-2 transition-colors">
          Servizi concierge
        </a>
      </div>
    </div>
  </section>

  <!-- Desktop hero (unchanged), hidden on mobile -->
  <div class="hidden md:block">
    <Hero
      images={heroImages}
      btnPrimaryHref={getLocalePath(lang, '/apartments')}
      btnGhostHref={getLocalePath(lang, '/concierge')}
    />
  </div>

  <!-- Featured Apartments -->
  <section class="section-padding bg-brand-bg">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div class="space-y-2">
          <p class="nav-link text-brand-accent">{t.home.featured.label}</p>
          <h2 class="font-display text-3xl lg:text-4xl text-brand-text tracking-tight">
            {t.home.featured.title}
          </h2>
        </div>
        <a href={getLocalePath(lang, '/apartments')} class="text-brand-muted text-sm hover:text-brand-text transition-colors hidden sm:block">
          {t.home.featured.viewAll}
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-brand-border">
        {featured.map(apt => (
          <div class="bg-brand-bg">
            <ApartmentCard apartment={apt} lang={lang} />
          </div>
        ))}
      </div>

      <div class="mt-6 sm:hidden">
        <a href={getLocalePath(lang, '/apartments')} class="text-brand-muted text-sm hover:text-brand-text transition-colors">
          {t.home.featured.viewAll}
        </a>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- Concierge hero -->
  <section class="ch-section">
    <img
      src="/images/concierge-hero.jpg"
      alt="Driver privato a Napoli, servizio transfer"
      loading="eager"
      decoding="async"
      class="ch-img"
    />
    <div class="ch-overlay" aria-hidden="true"></div>
    <div class="ch-content">
      <p class="ch-eyebrow">CONCIERGE SERVICES</p>
      <h2 class="ch-title">Un soggiorno senza compromessi</h2>
      <p class="ch-body">Ogni dettaglio del tuo soggiorno a Napoli, gestito con discrezione e cura. Dall'arrivo alla partenza.</p>
      <a href={getLocalePath(lang, '/concierge/services')} class="ch-cta">Scopri i servizi</a>
    </div>
  </section>

  <hr class="divider" />

  <!-- Chiaia teaser -->
  <section class="section-padding bg-brand-bg2">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center">
        <div class="space-y-6">
          <p class="nav-link text-brand-accent">{t.home.chiaia.eyebrow}</p>
          <h2 class="font-display text-3xl lg:text-4xl text-brand-text tracking-tight">
            {t.home.chiaia.title}
          </h2>
          <p class="text-brand-muted leading-relaxed">
            {t.home.chiaia.body}
          </p>
          <a href={getLocalePath(lang, '/chiaia')} class="btn-outline inline-block">
            {t.home.chiaia.cta}
          </a>
        </div>
        <div class="photo-placeholder-wide bg-brand-bg"></div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section-padding bg-brand-bg border-t border-brand-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center space-y-6">
      <h2 class="font-display text-3xl lg:text-5xl text-brand-text tracking-tight">
        {t.home.cta.title}
      </h2>
      <p class="text-brand-muted max-w-md mx-auto leading-relaxed">
        {t.home.cta.body}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center pt-2">
        <a href={getLocalePath(lang, '/book')} class="btn-solid">
          {t.home.cta.cta}
        </a>
        <a href={getLocalePath(lang, '/contact')} class="btn-outline">
          {t.home.cta.secondary}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
