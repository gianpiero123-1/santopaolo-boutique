---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, getLocalePath } from '../i18n/index';

const lang = 'it';
const t = useTranslations(lang);

const sections = [
  {
    key: 'around',
    title: 'Intorno a voi',
    body: 'Tutto ciò che rende Chiaia irresistibile è a portata di piedi dalla vostra porta.',
    places: [
      'Piazza dei Martiri, 2 min a piedi',
      'Lungomare Caracciolo, 5 min a piedi',
      'Castel dell\'Ovo, 10 min a piedi',
      'Via dei Mille e Via Filangieri, shopping di lusso',
    ],
  },
  {
    key: 'food',
    title: 'Dove mangiare',
    body: 'Una selezione editoriale, non una lista turistica.',
    categories: [
      { label: 'Pizza', items: ['Mattozzi', 'Salvo', '1000 Gourmet'] },
      { label: 'Ristoranti', items: ['Amici Miei', 'Signora Bettola', 'Cocoloco'] },
      { label: 'Street food', items: ['Prosciutteria TDV', 'Officina del Mare', 'L\'Oca Nera Burger'] },
      { label: 'Bar & Caffè', items: ['Gran Caffè Cimmino', 'Dream Café', 'Bar Guida'] },
    ],
  },
  {
    key: 'transport',
    title: 'Come spostarsi',
    body: 'Napoli è connessa. Da Chiaia ancora di più.',
    places: [
      'Metro Linea 6, fermata Chiaia',
      'Funicolare Centrale, da Augusteo',
      'Funicolare di Chiaia, da Parco Margherita',
      'Alibus Aeroporto, da Piazza Garibaldi',
    ],
  },
  {
    key: 'culture',
    title: 'Arte e Cultura',
    body: 'Il quartiere ha una vita culturale densa, spesso lontana dai circuiti turistici.',
    places: [
      'PAN, Palazzo delle Arti Napoli',
      'Tunnel Borbonico',
      'Museo Darwin-Dohrn',
    ],
  },
];
---

<BaseLayout
  title={`${t.chiaia.title} — ${t.meta.siteName}`}
  description={t.chiaia.intro}
  lang={lang}
>
  <!-- Hero -->
  <section class="relative min-h-[65vh] flex items-end bg-brand-bg overflow-hidden">
    <div class="absolute inset-0 bg-brand-bg2" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-t from-brand-bg via-brand-bg/40 to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 pb-16 lg:pb-24 w-full">
      <p class="nav-link text-brand-accent mb-3">{t.chiaia.eyebrow}</p>
      <h1 class="font-display text-5xl lg:text-8xl text-brand-text tracking-tight leading-none">
        {t.chiaia.title}
      </h1>
      <h4 class="font-display text-xl lg:text-2xl text-brand-muted mt-4">
        {t.chiaia.subtitle}
      </h4>
    </div>
  </section>

  <!-- Intro -->
  <section class="section-padding bg-brand-bg border-b border-brand-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-brand-text text-xl lg:text-2xl leading-relaxed max-w-3xl font-display">
        {t.chiaia.intro}
      </p>
    </div>
  </section>

  <!-- Sections grid -->
  <section class="section-padding bg-brand-bg">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-brand-border">
        {sections.map(section => (
          <div class="bg-brand-bg p-8 lg:p-12 space-y-5">
            <div class="photo-placeholder bg-brand-bg2 mb-6" style="aspect-ratio: 4/3;"></div>
            <h2 class="font-display text-2xl lg:text-3xl text-brand-text tracking-tight">
              {section.title}
            </h2>
            <p class="text-brand-muted leading-relaxed text-sm">
              {section.body}
            </p>

            {/* Place list */}
            {'places' in section && section.places && (
              <ul class="space-y-2 pt-1">
                {section.places.map(place => (
                  <li class="flex items-start gap-2 text-brand-muted text-sm">
                    <span class="mt-1.5 w-1 h-1 bg-brand-accent rounded-full flex-shrink-0" aria-hidden="true"></span>
                    {place}
                  </li>
                ))}
              </ul>
            )}

            {/* Food categories */}
            {'categories' in section && section.categories && (
              <div class="space-y-3 pt-1">
                {section.categories.map(cat => (
                  <div>
                    <p class="nav-link text-brand-accent text-xs mb-1">{cat.label}</p>
                    <p class="text-brand-muted text-sm">{cat.items.join(', ')}</p>
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-brand-bg2 border-t border-brand-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center space-y-5">
      <h2 class="font-display text-3xl lg:text-4xl text-brand-text tracking-tight">
        Esplora Chiaia da qui
      </h2>
      <p class="text-brand-muted max-w-md mx-auto">
        I nostri appartamenti sono in Vico Santa Maria a Cappella Vecchia 8b. A pochi passi da tutto.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={getLocalePath(lang, '/apartments')} class="btn-solid">
          {t.nav.apartments}
        </a>
        <a href={getLocalePath(lang, '/book')} class="btn-outline">
          {t.nav.book}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
