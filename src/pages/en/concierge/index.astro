---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import { useTranslations, getLocalePath } from '../../../i18n/index';
import servicesData from '../../../data/services.json';
import '../../../styles/concierge-hero.css';

const lang = 'en';
const t = useTranslations(lang);
const previewServices = servicesData.slice(0, 4);
---

<BaseLayout
  title={`${t.concierge.hero.eyebrow} — ${t.meta.siteName}`}
  description={t.concierge.hero.body}
  lang={lang}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="/images/concierge-hero.jpg" />
  </Fragment>

  <section class="ch-section ch-section--tall">
    <img
      src="/images/concierge-hero.jpg"
      alt="Private driver in Naples, transfer service"
      loading="eager"
      decoding="async"
      class="ch-img"
    />
    <div class="ch-overlay" aria-hidden="true"></div>
    <div class="ch-content">
      <p class="ch-eyebrow">{t.concierge.hero.eyebrow}</p>
      <h1 class="ch-title">{t.concierge.hero.title}</h1>
      <p class="ch-body">{t.concierge.hero.body}</p>
      <a href={getLocalePath(lang, '/concierge/services')} class="ch-cta">{t.concierge.hero.cta}</a>
    </div>
  </section>

  <section class="section-padding bg-brand-bg">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        {previewServices.map(service => (
          <ServiceCard service={service} lang={lang} />
        ))}
      </div>
      <div class="text-center">
        <a href={getLocalePath(lang, '/concierge/services')} class="btn-outline inline-block">{t.concierge.hero.cta}</a>
      </div>
    </div>
  </section>

  <section class="section-padding bg-brand-bg2 border-t border-brand-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center space-y-5">
      <h2 class="font-display text-3xl lg:text-4xl text-brand-text tracking-tight">Plan your stay</h2>
      <p class="text-brand-muted max-w-md mx-auto">Contact us before your arrival to organise every detail.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={getLocalePath(lang, '/contact')} class="btn-solid">{t.contact.title}</a>
        <a href={getLocalePath(lang, '/book')} class="btn-outline">{t.nav.book}</a>
      </div>
    </div>
  </section>
</BaseLayout>
