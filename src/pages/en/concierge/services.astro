---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import { useTranslations, getLocalePath } from '../../../i18n/index';
import servicesData from '../../../data/services.json';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t.concierge.services.title} — ${t.meta.siteName}`}
  description={t.concierge.services.subtitle}
  lang={lang}
>
  <section class="section-padding border-b border-brand-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="nav-link text-brand-accent mb-3">{t.concierge.hero.eyebrow}</p>
      <h1 class="font-display text-4xl lg:text-6xl text-brand-text tracking-tight mb-4">{t.concierge.services.title}</h1>
      <p class="text-brand-muted text-lg max-w-xl">{t.concierge.services.subtitle}</p>
    </div>
  </section>

  <section class="section-padding bg-brand-bg">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-brand-border">
        {servicesData.map(service => (
          <div class="bg-brand-bg"><ServiceCard service={service} lang={lang} /></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-brand-bg2 border-t border-brand-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-6">
      <div class="space-y-2">
        <h2 class="font-display text-2xl lg:text-3xl text-brand-text tracking-tight">Have a specific request?</h2>
        <p class="text-brand-muted">We are available for tailored and bespoke services.</p>
      </div>
      <a href={getLocalePath(lang, '/contact')} class="btn-solid flex-shrink-0">{t.concierge.services.cta}</a>
    </div>
  </section>
</BaseLayout>
