---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/index';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t.contact.title} — ${t.meta.siteName}`}
  description={t.contact.subtitle}
  lang={lang}
>
  <section class="section-padding border-b border-brand-border">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <p class="nav-link text-brand-accent mb-3">CONTACT</p>
      <h1 class="font-display text-4xl lg:text-6xl text-brand-text tracking-tight mb-4">
        Let's talk directly
      </h1>
      <p class="text-brand-muted text-lg max-w-xl">
        Bookings, apartment enquiries, concierge requests. Write or call, I'll reply personally.
      </p>
    </div>
  </section>

  <section class="section-padding bg-brand-bg">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col md:flex-row gap-6 md:gap-8">
        <!-- WhatsApp -->
        <a
          href="https://wa.me/393313225577"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 flex flex-col gap-5 p-8 md:p-10 rounded-2xl border border-[#1C1C1C] hover:border-[#6B1F1F] transition-colors"
        >
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#F5F2EC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z" />
          </svg>
          <div class="space-y-2">
            <p class="font-display text-brand-muted text-xs tracking-[0.2em] uppercase">WhatsApp</p>
            <p class="font-display text-brand-text text-2xl md:text-3xl">+39 331 322 5577</p>
            <p class="text-brand-muted text-sm">Quick reply, in English or Italian</p>
          </div>
        </a>

        <!-- Email -->
        <a
          href="mailto:gianpiero@santopaoloboutiqueapartments.com"
          class="flex-1 flex flex-col gap-5 p-8 md:p-10 rounded-2xl border border-[#1C1C1C] hover:border-[#6B1F1F] transition-colors"
        >
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#F5F2EC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          <div class="space-y-2">
            <p class="font-display text-brand-muted text-xs tracking-[0.2em] uppercase">Email</p>
            <p class="font-display text-brand-text text-xl md:text-2xl break-all">gianpiero@santopaoloboutiqueapartments.com</p>
            <p class="text-brand-muted text-sm">I reply within 24 hours</p>
          </div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
