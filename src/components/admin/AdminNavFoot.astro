---
interface Props {
  activePage: 'home' | 'calendar' | 'bookings' | 'tasks';
}

const { activePage } = Astro.props;

const links: { key: Props['activePage']; label: string; href: string }[] = [
  { key: 'home', label: 'Home', href: '/admin' },
  { key: 'calendar', label: 'Calendario', href: '/admin/calendar' },
  { key: 'bookings', label: 'Prenotazioni', href: '/admin/bookings' },
  { key: 'tasks', label: 'Task', href: '/admin/tasks' },
];
---

<nav class="nav-foot">
  {links.map((l) => (
    <a href={l.href} class={activePage === l.key ? 'active' : ''}>{l.label}</a>
  ))}
</nav>
