---
import type { Lang } from '../i18n/index';
import { useTranslations, getLocalePath } from '../i18n/index';

interface Apartment {
  id: number;
  slug: string;
  name: string;
  max_guests: number;
  bedrooms: number;
  bathrooms: number;
  size_sqm: number;
  hero_image: string;
  description_it: string;
  description_en: string;
}

interface Props {
  apartment: Apartment;
  lang: Lang;
  featured?: boolean;
}

const { apartment, lang, featured = false } = Astro.props;
const t = useTranslations(lang);
const href = getLocalePath(lang, `/apartments/${apartment.slug}`);
const bedroomsLabel = apartment.bedrooms === 0 ? 'Studio' : `${apartment.bedrooms} ${t.apartments.bedrooms}`;
const description = lang === 'it' ? apartment.description_it : apartment.description_en;
---

<article class="group border border-brand-border bg-brand-bg2 overflow-hidden">
  <a href={href} class="block overflow-hidden">
    <div class:list={['relative overflow-hidden', { 'photo-placeholder': !featured, 'aspect-video w-full': featured }]}>
      <img
        src={apartment.hero_image}
        alt={apartment.name}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
      />
    </div>
  </a>

  <div class:list={['p-6 lg:p-8 flex flex-col justify-between', { 'lg:p-10': featured }]}>
    <div class="space-y-4">
      <div class="flex items-center gap-4 text-brand-muted text-xs nav-link">
        <span>{apartment.size_sqm} {t.apartments.sqm}</span>
        <span aria-hidden="true">·</span>
        <span>{apartment.max_guests} {t.apartments.guests}</span>
        <span aria-hidden="true">·</span>
        <span>{bedroomsLabel}</span>
      </div>

      <h3 class:list={['font-display text-brand-text tracking-tight', { 'text-2xl lg:text-3xl': featured, 'text-xl': !featured }]}>
        <a href={href} class="hover:text-brand-accent transition-colors">
          {apartment.name}
        </a>
      </h3>

      <p class="text-brand-muted text-sm leading-relaxed line-clamp-3">
        {description}
      </p>
    </div>

    <div class="mt-6 pt-5 border-t border-brand-border">
      <a href={href} class="btn-outline text-xs py-2.5 px-5">
        {t.apartments.details}
      </a>
    </div>
  </div>
</article>
