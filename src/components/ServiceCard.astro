---
import type { Lang } from '../i18n/index';

interface Service {
  id: string;
  name: { it: string; en: string };
  description: { it: string; en: string };
}

interface Props {
  service: Service;
  lang: Lang;
}

const { service, lang } = Astro.props;

const svgInner: Record<string, string> = {
  'transfer':
    `<path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>`,
  'boat-tour':
    `<circle cx="12" cy="5" r="3"/><path d="M12 8v14M4 11h16M5.5 21.5c0-3 3.3-5.5 6.5-5.5s6.5 2.5 6.5 5.5"/>`,
  'car-rental':
    `<path d="M5 17H3v-4l3-7h12l3 7v4h-2"/><circle cx="8" cy="17" r="2"/><circle cx="16" cy="17" r="2"/>`,
  'restaurants':
    `<path d="M3 2v7a3 3 0 006 0V2M6 9v13M21 15V2a5 5 0 00-5 5v6c0 .6.4 1 1 1h4v6"/>`,
  'food-experience':
    `<path d="M8 3h8l-2 9a4 4 0 01-8 0L8 3zM5 21h14M12 12v9"/>`,
  'private-tours':
    `<path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7z"/><circle cx="12" cy="9" r="2.5"/>`,
  'personal-shopping':
    `<path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/>`,
  'concierge-247':
    `<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.1a19.79 19.79 0 01-3.07-8.63A2 2 0 012.18 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 9.91a16 16 0 006.59 6.59l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>`,
};
---

<article class="flex flex-col h-full bg-brand-bg2 p-8 border border-[rgba(245,242,236,0.06)] hover:border-brand-accent transition-colors duration-200 group">
  <div class="mb-6">
    <svg
      width="32"
      height="32"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-brand-muted"
      aria-hidden="true"
      set:html={svgInner[service.id] ?? svgInner['concierge-247']}
    />
  </div>

  <h3 class="font-display text-brand-text text-lg leading-tight tracking-tight mb-3 group-hover:text-brand-accent transition-colors duration-200">
    {service.name[lang]}
  </h3>

  <p class="text-brand-muted text-sm leading-relaxed">
    {service.description[lang]}
  </p>
</article>
