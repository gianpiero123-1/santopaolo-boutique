---
import apartments from '../data/apartments.json';

interface Props {
  lang?: 'it' | 'en';
  tagline?: string;
  btnPrimary?: string;
  btnPrimaryHref?: string;
  btnGhost?: string;
  btnGhostHref?: string;
}

const copy = {
  it: {
    tagline: '5 appartamenti boutique nel cuore di Chiaia, Napoli',
    btnPrimary: 'Scopri gli appartamenti',
    btnGhost: 'Servizi concierge',
  },
  en: {
    tagline: '5 boutique apartments in the heart of Chiaia, Naples',
    btnPrimary: 'Discover the apartments',
    btnGhost: 'Concierge services',
  },
};

const {
  lang = 'it',
  tagline,
  btnPrimary,
  btnPrimaryHref = '/apartments',
  btnGhost,
  btnGhostHref = '/concierge',
} = Astro.props;

const t = copy[lang] ?? copy.it;
const taglineText = tagline ?? t.tagline;
const btnPrimaryText = btnPrimary ?? t.btnPrimary;
const btnGhostText = btnGhost ?? t.btnGhost;

// 8 photos for the background grid: 2 from unit 1, 2 from unit 2,
// 1 from unit 3, 1 from unit 4, 2 from unit 5.
const heroPhotos = [
  apartments[0].gallery[0],
  apartments[0].gallery[1],
  apartments[1].gallery[0],
  apartments[1].gallery[1],
  apartments[2].gallery[0],
  apartments[3].gallery[0],
  apartments[4].gallery[0],
  apartments[4].gallery[1],
];
---

<section class="relative min-h-screen w-full bg-[#0E0E0E] overflow-hidden flex items-center justify-center">

  <!-- GRIGLIA FOTO BACKGROUND -->
  <div class="absolute inset-0 hidden md:grid grid-cols-4 grid-rows-2 gap-2 p-2 z-0">
    {heroPhotos.map((src) => (
      <img src={src} alt="" loading="lazy" decoding="async" class="w-full h-full object-cover rounded-2xl opacity-40" />
    ))}
  </div>

  <!-- OVERLAY SCURO PER LEGGIBILITÀ LOGO -->
  <!-- (radial-gradient via inline style: Tailwind has no `bg-gradient-radial` utility) -->
  <div
    class="absolute inset-0 z-10"
    style="background: radial-gradient(ellipse at center, rgba(14,14,14,0.30) 0%, rgba(14,14,14,0.60) 55%, rgba(14,14,14,0.90) 100%);"
  ></div>

  <!-- CONTENUTO CENTRALE -->
  <div class="relative z-20 flex flex-col items-center justify-center text-center px-6">

    <!-- LOGO COMPLETO (stesso file della Navbar: /logo-santopaolo-light.svg, nessun filtro) -->
    <img
      src="/logo-santopaolo-dark.svg"
      alt="Santopaolo Boutique Apartments"
      class="w-auto h-48 md:h-64 lg:h-80 mb-8"
    />

    <div class="flex flex-col sm:flex-row gap-4">
      <a href={btnPrimaryHref} class="px-8 py-4 bg-[#6B1F1F] hover:bg-[#8A2A2A] text-[#F5F2EC] tracking-[0.2em] text-sm uppercase transition-colors">
        {btnPrimaryText}
      </a>
      <a href={btnGhostHref} class="px-8 py-4 border border-[#F5F2EC]/40 hover:border-[#F5F2EC] text-[#F5F2EC] tracking-[0.2em] text-sm uppercase transition-colors">
        {btnGhostText}
      </a>
    </div>

  </div>

</section>
