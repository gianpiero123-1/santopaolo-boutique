---
interface Props {
  images?: string[];
  eyebrow?: string;
  titleHtml?: string;
  sub?: string;
  btnPrimary?: string;
  btnPrimaryHref?: string;
  btnGhost?: string;
  btnGhostHref?: string;
}

const {
  images = [
    '/images/apartments/1.jpg',
    '/images/apartments/2.jpg',
    '/images/apartments/3.jpg',
    '/images/apartments/4.jpg',
    '/images/apartments/5.jpg',
    '/images/apartments/1b.jpg',
    '/images/apartments/3b.jpg',
    '/wellness/gym/gym-01.jpg',
    '/wellness/steam/steam-01.jpg',
  ],
  eyebrow = 'Chiaia, Napoli',
  titleHtml = 'Cinque boutique<br />apartments nel cuore<br />di Chiaia',
  sub = 'Ospitalità privata, design contemporaneo, un quartiere unico.',
  btnPrimary = 'Scopri gli appartamenti',
  btnPrimaryHref = '/apartments',
  btnGhost = 'Servizi concierge',
  btnGhostHref = '/concierge',
} = Astro.props;
---

<section class="hero relative flex items-center justify-center overflow-hidden">

  <!-- Mobile full-bleed background, visible only on small screens -->
  <div class="hero__mobile-img" style={`background-image: url('${images[0]}')`} aria-hidden="true">
    <div class="hero__mobile-overlay"></div>
  </div>

  <!-- Layer A (z-10): polaroid crown -->
  <div class="hero__cards" aria-hidden="true">
    {images.map((src, i) => (
      <div class={`photo-card photo-card--${i + 1}`}>
        <img
          src={src}
          alt=""
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          onerror="this.parentElement.style.display='none'"
        />
      </div>
    ))}
  </div>

  <!-- Layer vignette (z-15): radial dark gradient for text legibility -->
  <div class="hero__vignette" aria-hidden="true"></div>

  <!-- Layer B (z-20): centered logo + CTAs -->
  <div class="relative z-20 flex flex-col items-center px-6 text-center">
    <img
      src="/logos/santopaolo-vertical-light.svg"
      alt="Santopaolo Boutique Apartments"
      class="w-[280px] md:w-[420px] lg:w-[520px] h-auto"
    />
    <div class="mt-12 md:mt-16 flex flex-col md:flex-row items-center gap-4 md:gap-6">
      <a
        href={btnPrimaryHref}
        class="inline-block bg-[#6B1F1F] hover:bg-[#8A2A2A] text-[#F5F2EC] uppercase tracking-[0.15em] text-xs py-4 px-7 transition-colors"
      >
        {btnPrimary}
      </a>
      <a
        href={btnGhostHref}
        class="inline-block border border-[#8A8580] hover:border-[#F5F2EC] text-[#F5F2EC] uppercase tracking-[0.15em] text-xs py-4 px-7 transition-colors"
      >
        {btnGhost}
      </a>
    </div>
  </div>

</section>

<style>
  /* ===== SECTION ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: max(100vh, 800px);
    background: #0E0E0E;
    overflow: hidden;
  }

  /* ===== MOBILE FULL-BLEED IMAGE (hidden on desktop) ===== */
  .hero__mobile-img {
    display: none;
    position: absolute;
    inset: 0;
    z-index: 5;
    background-size: cover;
    background-position: center;
  }

  .hero__mobile-overlay {
    position: absolute;
    inset: 0;
    background: rgba(14, 14, 14, 0.7);
  }

  /* ===== LAYER A (z-10): polaroid crown ===== */
  .hero__cards {
    position: absolute;
    inset: 0;
    z-index: 10;
  }

  .photo-card {
    position: absolute;
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.5),
      0 8px 20px rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(245, 242, 236, 0.06);
    opacity: 0.55;
    filter: brightness(0.9) saturate(0.95);
    width: 220px;
    aspect-ratio: 3 / 4;
    transition: opacity 0.4s ease;
    animation: cardEnter 0.7s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    will-change: opacity;
  }

  .photo-card:hover {
    opacity: 0.85;
  }

  .photo-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* TOP ROW (3 cards) */
  .photo-card--1 { top: 8%;    left: 6%;   rotate: -6deg; animation-delay: 0ms;   }
  .photo-card--2 { top: 4%;    left: 38%;  rotate:  4deg; animation-delay: 80ms;  }
  .photo-card--3 { top: 8%;    right: 6%;  rotate:  7deg; animation-delay: 160ms; }

  /* MIDDLE SIDES (2 cards) */
  .photo-card--4 { top: 38%;   left: 2%;   rotate: -4deg; animation-delay: 240ms; }
  .photo-card--5 { top: 38%;   right: 2%;  rotate:  5deg; animation-delay: 320ms; }

  /* BOTTOM ROW (4 cards) */
  .photo-card--6 { bottom: 6%; left: 6%;   rotate:  6deg; animation-delay: 400ms; }
  .photo-card--7 { bottom: 4%; left: 32%;  rotate: -5deg; animation-delay: 480ms; }
  .photo-card--8 { bottom: 4%; right: 32%; rotate:  4deg; animation-delay: 560ms; }
  .photo-card--9 { bottom: 6%; right: 6%;  rotate: -7deg; animation-delay: 640ms; }

  @keyframes cardEnter {
    from {
      opacity: 0;
      translate: 0 24px;
      scale: 0.95;
    }
    to {
      opacity: 0.55;
      translate: 0 0;
      scale: 1;
    }
  }

  /* ===== LAYER VIGNETTE (z-15): radial dark center for text legibility ===== */
  .hero__vignette {
    position: absolute;
    inset: 0;
    z-index: 15;
    pointer-events: none;
    background: radial-gradient(
      ellipse at center,
      rgba(14, 14, 14, 0.85) 0%,
      rgba(14, 14, 14, 0) 70%
    );
  }

  /* ===== TABLET (≤1024px): 6 cards at 140px ===== */
  @media (max-width: 1024px) {
    .photo-card { width: 140px; }
    .photo-card--2,
    .photo-card--7,
    .photo-card--8 { display: none; }
  }

  /* ===== MOBILE (≤640px): full-bleed image, no cards ===== */
  @media (max-width: 640px) {
    .hero__mobile-img { display: block; }
    .hero__cards { display: none; }
    .hero__vignette { display: none; }
  }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    .photo-card {
      animation: none;
      opacity: 0.55;
    }
  }
</style>
